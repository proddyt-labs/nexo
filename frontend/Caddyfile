:80 {
	root * /srv
	encode gzip zstd

	# API e WebSocket → backend
	@api path /api/* /socket.io/*
	handle @api {
		reverse_proxy nexo-backend:3200
	}

	# Assets com hash no nome → cache eterno
	@assets path /assets/*
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Tudo mais (HTML / SPA fallback) → no-store
	handle {
		header Cache-Control "no-store, no-cache, must-revalidate"
		try_files {path} /index.html
		file_server
	}
}

# Backend
# IMPORTANTE: usar ?pgbouncer=true pra desabilitar prepared statements
# (workaround pra bug de cache do Prisma 5 com Postgres 16)
DATABASE_URL="postgresql://nexo:nexo_pass@localhost:5433/nexo?pgbouncer=true"
PORT=3200
FRONTEND_URL="http://localhost:5173"

# Gate SSO (backend)
GATE_URL="http://localhost:3100"
GATE_CLIENT_ID="nexo"
GATE_CLIENT_SECRET=""

# Produção (docker-compose.prod.yml)
DB_PASSWORD="senha-segura-aqui"

# Frontend (Vite — colocar em frontend/.env)
# VITE_GATE_URL=http://localhost:3100
# VITE_CLIENT_ID=nexo
# VITE_REDIRECT_URI=http://localhost:5173/auth/callback
